import turtle
import random

window = 500
radius = 180
dash = 12
center_x = 0
center_y = 0
spead = 50

screen = turtle.Screen()
screen.setup(window, window)
screen.bgcolor("white")
turtle.colormode(255)

turtle.penup()
turtle.goto(0, -radius)
turtle.pendown()
turtle.pensize(1)
turtle.circle(radius)

bob = turtle.Turtle()
bob.shape("circle")
bob.penup()
bob.goto(0, 0)
bob.pendown()

while True:
    angle = random.randint(0, 180)
    steps = random.randint(5, 20)
    bob.setheading(angle)

    r = random.randint(0,255)
    g = random.randint(0,255)
    b = random.randint(0,255)
    bob.pencolor(r, g, b)

    for i in range(steps):
        bob.pendown()
        bob.forward(dash)
        bob.penup()
        bob.forward(dash)

    if bob.distance(center_x, center_y) >= radius - 10:
        angle_to_center = bob.towards(center_x, center_y)
        bob.setheading(angle_to_center)
        bob.goto(center_x, center_y)
        bob.pendown()

turtle.done()
